{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "@tools/dotnetprobe",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec node ./build.mjs",
        "cwd": "{projectRoot}"
      },
      "cache": true,
      "inputs": [
        "{projectRoot}/dotnetprobe.csproj",
        "{projectRoot}/Program.cs",
        "{projectRoot}/nuget.config",
        { "runtime": "dotnet --version" },
        { "runtime": "node -p process.platform" }
      ],
      "outputs": ["{projectRoot}/dist"]
    },
    "build:win": {
      "executor": "nx:run-commands",
      "options": {
        "command": "dotnet publish -r win-x64 -o temp",
        "cwd": "{projectRoot}"
      },
      "cache": true,
      "inputs": [
        "{projectRoot}/dotnetprobe.csproj",
        "{projectRoot}/Program.cs",
        "{projectRoot}/nuget.config",
        { "runtime": "dotnet --version" }
      ],
      "outputs": ["{projectRoot}/temp/dotnetprobe.exe"]
    }
  }
}
