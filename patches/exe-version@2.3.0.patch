+
+    // VS_FIXEDFILEINFO layout (offsets from dwSignature):
+    //   +0  dwSignature        (0xFEEF04BD)
+    //   +4  dwStrucVersion
+    //   +8  dwFileVersionMS    HIWORD=major  LOWORD=minor
+    //   +12 dwFileVersionLS    HIWORD=patch  LOWORD=build
+    //   +16 dwProductVersionMS
+    //   +20 dwProductVersionLS
