+    const minor =  ms         & 0xFFFF;
+    const patch = (ls >>> 16) & 0xFFFF;
+    const build =  ls         & 0xFFFF;
+
+    return `${major}.${minor}.${patch}.${build}`;
+  } catch (_) {
+    return '0.0.0';
+  }
