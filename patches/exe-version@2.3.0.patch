+    //   +0  OffsetToData (RVA, 4)
+    //   +4  Size (4)
+    //   +8  CodePage (4)
+    //   +12 Reserved (4)
+    const dataEntOff = rsrcBase + l3;
+    const dataRva    = buf.readUInt32LE(dataEntOff);
+    const dataOff    = rvaToOffset(dataRva);
+    if (dataOff < 0) return '0.0.0';
+
+    // ── Locate VS_FIXEDFILEINFO via its signature ──────────────────────────
+    //
+    // VS_VERSIONINFO layout:
+    //   wLength (2) + wValueLength (2) + wType (2) + szKey "VS_VersionInfo\0"
+    //   in UTF-16LE (30 bytes) = 36 bytes total, 4-byte aligned → no padding.
+    //   VS_FIXEDFILEINFO follows at offset +36.
+    //
+    // Rather than hard-coding offset 36 we scan for the 0xFEEF04BD magic,
+    // which tolerates any compiler-introduced padding variations.
+    let fixOff = -1;
+    const scanEnd = Math.min(dataOff + 256, buf.length - 20);
+    for (let i = dataOff; i < scanEnd; i++) {
+      if (buf.readUInt32LE(i) === 0xFEEF04BD) { fixOff = i; break; }
+    }
