+function _readPeVersion(filePath, useProduct) {
+  const fs = require('fs');
+  let buf;
+  try {
+    buf = fs.readFileSync(filePath);
+  } catch (_) {
+    return '0.0.0';
+  }
+
+  try {
+    // ── MZ header ──────────────────────────────────────────────────────────
+    if (buf.length < 64 || buf.readUInt16LE(0) !== 0x5A4D) return '0.0.0';
+
+    const peOffset = buf.readUInt32LE(0x3C);
+    if (peOffset + 24 > buf.length) return '0.0.0';
+
+    // ── PE signature ───────────────────────────────────────────────────────
+    if (buf.readUInt32LE(peOffset) !== 0x00004550) return '0.0.0'; // 'PE\0\0'
+
+    // ── COFF header (20 bytes after PE sig) ────────────────────────────────
+    const coffOffset   = peOffset + 4;
+    const numSections  = buf.readUInt16LE(coffOffset + 2);
+    const sizeOfOptHdr = buf.readUInt16LE(coffOffset + 16);
+
+    // ── Optional header ────────────────────────────────────────────────────
+    const optOffset = coffOffset + 20;
+    if (sizeOfOptHdr < 2) return '0.0.0';
+    const magic   = buf.readUInt16LE(optOffset);
+    const isPe32p = magic === 0x020B; // PE32+ (64-bit)
+
+    // Data directories start at different offsets in PE32 vs PE32+
+    //   PE32:  optional header byte 96
+    //   PE32+: optional header byte 112
+    const ddBase = optOffset + (isPe32p ? 112 : 96);
+
+    // Resource directory = data directory index 2 (each entry = 8 bytes: RVA + Size)
+    if (ddBase + 2 * 8 + 4 > buf.length) return '0.0.0';
+    const rsrcRva = buf.readUInt32LE(ddBase + 2 * 8);
+    if (rsrcRva === 0) return '0.0.0';
+
+    // ── Section table ──────────────────────────────────────────────────────
+    const sectionTableOffset = optOffset + sizeOfOptHdr;
+
+    /**
+     * Convert a virtual address (RVA) to a file offset using the section table.
+     * @param {number} rva
+     * @returns {number}  File offset, or -1 if not found
+     */
+    const rvaToOffset = (rva) => {
+      for (let i = 0; i < numSections; i++) {
+        const s   = sectionTableOffset + i * 40;
+        const va  = buf.readUInt32LE(s + 12); // VirtualAddress
+        const vs  = buf.readUInt32LE(s + 8);  // VirtualSize
+        const raw = buf.readUInt32LE(s + 20); // PointerToRawData
+        if (rva >= va && rva < va + vs) return raw + (rva - va);
+      }
+      return -1;
+    };
+
+    const rsrcBase = rvaToOffset(rsrcRva);
+    if (rsrcBase < 0) return '0.0.0';
+
+    // ── Resource directory helpers ─────────────────────────────────────────
+    //
+    // IMAGE_RESOURCE_DIRECTORY (16 bytes):
+    //   +0  Characteristics (4)
+    //   +4  TimeDateStamp (4)
+    //   +8  MajorVersion (2)
+    //   +10 MinorVersion (2)
+    //   +12 NumberOfNamedEntries (2)
+    //   +14 NumberOfIdEntries (2)
+    //
+    // IMAGE_RESOURCE_DIRECTORY_ENTRY (8 bytes):
+    //   +0  NameOffset/Id (4)  — bit 31 set = named string
+    //   +4  OffsetToData  (4)  — bit 31 set = subdirectory; else leaf
