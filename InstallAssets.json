    },
    {
      "srcPath": "src/renderer/src/index.html",
      "outPath": "",
      "target": ["out", "dist"],
      "skipPaths": 3
    },
    {
      "srcPath": "src/queries",
      "outPath": "",
      "target": ["out", "dist"],
      "skipPaths": 1
