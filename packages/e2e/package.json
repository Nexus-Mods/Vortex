{
  "$schema": "https://www.schemastore.org/package.json",
  "name": "@vortex/e2e",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm exec cross-env VORTEX_E2E_INSPECT=1 pnpm exec playwright test --workers=1",
    "dev:explore": "pnpm exec cross-env VORTEX_E2E_HEADED=1 pnpm exec tsx ./src/vortex-instance.ts --debug",
    "e2e": "pnpm exec playwright test",
    "e2e:headed": "pnpm exec cross-env VORTEX_E2E_HEADED=1 pnpm exec playwright test",
    "e2e:ui": "pnpm exec cross-env VORTEX_E2E_HEADED=1 pnpm exec playwright test --ui",
    "typecheck": "pnpm exec tsc",
    "lint": "pnpm exec eslint --quiet --concurrency auto .",
    "lint:verbose": "pnpm exec eslint --concurrency auto .",
    "ci-report": "pnpm exec tsx ./ci-report.ts"
  },
  "nx": {
    "targets": {
      "dev": {
        "cache": false,
        "dependsOn": [
          {
            "target": "build",
            "projects": "@vortex/main"
          }
        ]
      },
      "dev:explore": {
        "cache": false,
        "continuous": true,
        "dependsOn": [
          {
            "target": "build",
            "projects": "@vortex/main"
          }
        ]
      },
      "e2e": {
        "cache": false,
        "dependsOn": [
          {
            "target": "build",
            "projects": "@vortex/main"
          }
        ]
      },
      "e2e:headed": {
        "cache": false,
        "dependsOn": [
          {
            "target": "build",
            "projects": "@vortex/main"
          }
        ]
      },
      "e2e:ui": {
        "cache": false,
        "continuous": true,
        "dependsOn": [
          {
            "target": "build",
            "projects": "@vortex/main"
          }
        ]
      }
    }
  },
  "devDependencies": {
    "@playwright/test": "catalog:",
    "@types/node": "catalog:",
    "electron": "catalog:",
    "enquirer": "catalog:",
    "octokit": "catalog:",
    "playwright": "catalog:",
    "tsx": "catalog:"
  }
}
