{
  "$schema": "https://www.schemastore.org/package.json",
  "name": "@vortex/adaptor-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm tsdown",
    "dist": "pnpm tsdown",
    "typecheck": "pnpm tsc",
    "test": "pnpm vitest run",
    "lint": "pnpm eslint --concurrency auto .",
    "lint:quiet": "pnpm eslint --concurrency auto --quiet ."
  },
  "dependencies": {
    "@vortex/fs": "workspace:*"
  },
  "peerDependencies": {
    "rolldown": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "rolldown": "catalog:"
  },
  "exports": {
    ".": {
      "development": "./src/lib.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./contracts/game-info": {
      "development": "./src/contracts/game-info.ts",
      "import": "./dist/contracts/game-info.js",
      "require": "./dist/contracts/game-info.cjs"
    },
    "./contracts/game-installer": {
      "development": "./src/contracts/game-installer.ts",
      "import": "./dist/contracts/game-installer.js",
      "require": "./dist/contracts/game-installer.cjs"
    },
    "./contracts/game-paths": {
      "development": "./src/contracts/game-paths.ts",
      "import": "./dist/contracts/game-paths.js",
      "require": "./dist/contracts/game-paths.cjs"
    },
    "./contracts/game-tools": {
      "development": "./src/contracts/game-tools.ts",
      "import": "./dist/contracts/game-tools.js",
      "require": "./dist/contracts/game-tools.cjs"
    },
    "./contracts/ping": {
      "development": "./src/contracts/ping.ts",
      "import": "./dist/contracts/ping.js",
      "require": "./dist/contracts/ping.cjs"
    },
    "./plugin": {
      "development": "./src/plugin.ts",
      "import": "./dist/plugin.js",
      "require": "./dist/plugin.cjs"
    },
    "./stores/lib": {
      "development": "./src/stores/lib.ts",
      "import": "./dist/stores/lib.js",
      "require": "./dist/stores/lib.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      },
      "./contracts/game-info": {
        "import": "./dist/contracts/game-info.js",
        "require": "./dist/contracts/game-info.cjs"
      },
      "./contracts/game-installer": {
        "import": "./dist/contracts/game-installer.js",
        "require": "./dist/contracts/game-installer.cjs"
      },
      "./contracts/game-paths": {
        "import": "./dist/contracts/game-paths.js",
        "require": "./dist/contracts/game-paths.cjs"
      },
      "./contracts/game-tools": {
        "import": "./dist/contracts/game-tools.js",
        "require": "./dist/contracts/game-tools.cjs"
      },
      "./contracts/ping": {
        "import": "./dist/contracts/ping.js",
        "require": "./dist/contracts/ping.cjs"
      },
      "./plugin": {
        "import": "./dist/plugin.js",
        "require": "./dist/plugin.cjs"
      },
      "./stores/lib": {
        "import": "./dist/stores/lib.js",
        "require": "./dist/stores/lib.cjs"
      },
      "./package.json": "./package.json"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.cts"
}
