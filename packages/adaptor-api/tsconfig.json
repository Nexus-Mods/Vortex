{
  "$schema": "https://www.schemastore.org/tsconfig.json",
  "extends": "../../tsconfig.strict.json",
  "include": ["src/**/*"],
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowJs": false,
    "composite": true,
    "declaration": true,
    "noEmit": true,
    "types": [],
    "lib": ["ESNext"],
    "isolatedDeclarations": true,
    "paths": {
      "@nexusmods/adaptor-api": ["./src/lib.ts"]
    }
  }
}
