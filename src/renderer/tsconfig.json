{
  "$schema": "https://www.schemastore.org/tsconfig.json",
  "extends": "../../tsconfig.base.json",
  "include": [
    "src/**/*",
    "./test-setup.ts",
    "../../typings.custom/*.d.ts",
    "src/typings.custom/*.d.ts"
  ],
  "exclude": [
    "src/__mocks__/",
    "src/__tests__/",
    "./dist",
    "./temp",
    "./lib",
    "node_modules"
  ],
  "compilerOptions": {
    "composite": true,
    "noEmit": true,
    "target": "esnext",
    "module": "node16", // TODO: change to esnext
    "moduleResolution": "node16", // TODO: change to bundler
    "jsx": "react",
    "lib": [
      "ESNext",
      "DOM",
      "DOM.Iterable"
    ]
  }
}
