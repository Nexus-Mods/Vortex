{
  "$schema": "https://www.schemastore.org/tsconfig.json",
  "extends": "../../tsconfig.base.json",
  "include": [
    "**/*",
    "../../webpack.base.cjs",
    "../../typings.custom/*.d.ts",
    "./typings.custom/*.d.ts"
  ],
  "exclude": [
    "./__mocks__/",
    "./__tests__/",
    "./dist",
    "./temp",
    "node_modules"
  ],
  "compilerOptions": {
    "composite": true,
    "noEmit": true,
    "target": "esnext",
    "module": "node16", // TODO: change to esnext
    "moduleResolution": "node16", // TODO: change to bundler
    "jsx": "react-jsx",
    "lib": ["ESNext", "DOM", "DOM.Iterable"]
  }
}
