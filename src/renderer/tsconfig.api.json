{
  "$schema": "https://www.schemastore.org/tsconfig.json",
  "extends": "../../tsconfig.base.json",
  "include": [
    "src/api.ts",
    "src/preload.ts",
    "../../typings.custom/index.d.ts"
  ],
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "declaration": true,
    "emitDeclarationOnly": true,
    "jsx": "react-jsx",
    "outDir": "lib",
    "rootDir": "src",
    "removeComments": false,
    "lib": [
      "ESNext",
      "DOM",
      "DOM.Iterable"
    ]
  }
}
