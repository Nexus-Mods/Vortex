{
  "$schema": "https://www.schemastore.org/package.json",
  "name": "@vortex/main",
  "author": "Black Tree Gaming Ltd.",
  "license": "GPL-3.0-only",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "main": "build/main.cjs",
  "scripts": {
    "start": "pnpm electron .",
    "build": "node ./build.mjs",
    "typecheck": "pnpm tsc",
    "lint": "pnpm eslint --quiet --concurrency auto .",
    "lint:verbose": "pnpm eslint --concurrency auto .",
    "test": "pnpm vitest run --config ./vitest.config.ts",
    "test:downloader": "pnpm vitest run --config ./vitest.downloader.config.ts",
    "test:adaptor": "pnpm vitest run --config ./vitest.integration.config.ts",
    "publish": "pnpm exec rimraf ./dist && pnpm -F @vortex/main deploy ./dist && node ./dist/prepare-dist-package.mjs",
    "package": "cd ./dist && pnpm electron-builder --config ./electron-builder.config.json --config.win.forceCodeSigning=true --config.win.sign=./sign.cjs --publish never",
    "package:nosign": "cd ./dist && pnpm electron-builder --config ./electron-builder.config.json --publish never"
  },
  "nx": {
    "targets": {
      "start": {
        "continuous": true,
        "cache": false,
        "dependsOn": [
          "build"
        ]
      },
      "build": {
        "dependsOn": [
          "copy-assets",
          "copy-extensions",
          "^build"
        ],
        "cache": false
      },
      "publish": {
        "dependsOn": [
          "build"
        ]
      },
      "package": {
        "cache": false,
        "dependsOn": [
          "publish"
        ]
      },
      "package:nosign": {
        "cache": false,
        "dependsOn": [
          "publish"
        ]
      },
      "copy-assets": {
        "executor": "nx:run-commands",
        "options": {
          "command": "node ./copy-assets.mjs",
          "cwd": "{projectRoot}"
        },
        "dependsOn": [
          {
            "target": "build",
            "projects": "@vortex/stylesheets"
          }
        ],
        "cache": true,
        "inputs": [
          "default",
          {
            "dependentTasksOutputFiles": "**/dist/**"
          },
          "{projectRoot}/copy-assets.mjs",
          "{workspaceRoot}/src/stylesheets/**/*.scss",
          "{workspaceRoot}/src/renderer/src/index.html",
          "{workspaceRoot}/src/renderer/src/splash.html",
          "{workspaceRoot}/src/queries/**/*",
          "{workspaceRoot}/assets/**/*",
          "{workspaceRoot}/LICENSE.md"
        ],
        "outputs": [
          "{projectRoot}/build/assets/",
          "{projectRoot}/build/queries/",
          "{projectRoot}/build/index.html",
          "{projectRoot}/build/splash.html",
          "{projectRoot}/build/LICENSE.md",
          "{projectRoot}/build/modules.json"
        ]
      },
      "copy-extensions": {
        "executor": "nx:run-commands",
        "options": {
          "command": "node ./copy-extensions.mjs",
          "cwd": "{projectRoot}"
        },
        "dependsOn": [
          {
            "target": "build",
            "projects": "tag:vortex:extension"
          }
        ],
        "cache": true,
        "inputs": [
          "default",
          {
            "dependentTasksOutputFiles": "**/dist/**"
          },
          "{projectRoot}/copy-extensions.mjs"
        ],
        "outputs": [
          "{projectRoot}/build/bundledPlugins/"
        ]
      }
    }
  },
  "files": [
    "./build",
    "./nsis/",
    "./electron-builder.config.json",
    "./prepare-dist-package.mjs",
    "./sign.cjs"
  ],
