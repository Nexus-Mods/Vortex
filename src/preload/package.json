{
  "$schema": "https://www.schemastore.org/package.json",
  "name": "@vortex/preload",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "node ./build.mjs",
    "typecheck": "pnpm tsc",
    "lint": "pnpm eslint --quiet --concurrency auto .",
    "lint:verbose": "pnpm eslint --concurrency auto ."
  },
  "nx": {
    "targets": {
      "build": {
        "outputs": [
          "{workspaceRoot}/src/main/build/preload.*"
        ]
      }
    }
  },
  "devDependencies": {
    "electron": "catalog:"
  },
  "dependencies": {
    "@vortex/shared": "workspace:*"
  }
}
