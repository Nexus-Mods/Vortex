{
  "$schema": "https://www.schemastore.org/package.json",
  "name": "@vortex/preload",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "pnpm cross-env NODE_ENV=development pnpm webpack --config ./webpack.config.cjs",
    "dist": "pnpm cross-env NODE_ENV=production pnpm webpack --config ./webpack.config.cjs",
    "typecheck": "pnpm tsc --noEmit --composite false -p tsconfig.json"
  },
  "devDependencies": {
    "electron": "catalog:"
  },
  "dependencies": {
    "@vortex/shared": "workspace:*"
  }
}
