{
  // NOTE(erri120): This TSConfig file is only for node scripts and config files used during development
  "$schema": "https://www.schemastore.org/tsconfig.json",
  "include": [
    "./BuildSubprojects.mjs",
    "./InstallAssets.mjs",
    "./eslint-rules/*.mjs",
    "./eslint.config.mjs",
    "./scripts/*.mjs",
    "./src/main/prepare-dist-package.mjs",
    "./src/renderer/vitest.config.ts",
    "./src/shared/tsdown.config.ts",
    "./ts-to-zod.config.mjs",
    "./vitest.config.ts"
  ],
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "composite": true,
    "noEmit": true,
    "allowJs": true,
    "types": ["node"]
  }
}
