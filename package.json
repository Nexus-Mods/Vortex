    "preinstall": "npx only-allow pnpm",
    "build:fomod": "node ./preinstall.js",
    "start": "pnpm -F @vortex/main run start",
    "build": "pnpm -r run build",
    "dist": "pnpm -r run dist",
    "package": "pnpm run dist && pnpm run assets:dist && pnpm run subprojects:dist && pnpm -F @vortex/main run package",
    "package:nosign": "pnpm run dist && pnpm run assets:dist && pnpm run subprojects:dist && pnpm -F @vortex/main run package:nosign",
    "assets:out": "node ./InstallAssets.mjs ./src/main/out && pnpm sass --style compressed ./src/stylesheets/loadingScreen.scss ./src/main/out/assets/css/loadingScreen.css && pnpm tailwindcss -i ./src/stylesheets/tailwind-v4.css -o ./src/main/out/assets/css/tailwind-v4.css -m",
    "assets:dist": "node ./InstallAssets.mjs ./src/main/dist && pnpm sass --style compressed ./src/stylesheets/loadingScreen.scss ./src/main/dist/assets/css/loadingScreen.css && pnpm tailwindcss -i ./src/stylesheets/tailwind-v4.css -o ./src/main/dist/assets/css/tailwind-v4.css -m",
    "subprojects:out": "node ./BuildSubprojects.mjs ./src/main/out",
    "subprojects:dist": "node ./BuildSubprojects.mjs ./src/main/dist",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "api": "pnpm -F @vortex/renderer run api:build && pnpm -F @vortex/renderer run api:docs",
    "lint": "pnpm eslint --cache --concurrency auto .",
    "lint:quiet": "pnpm eslint --cache --concurrency auto --quiet .",
    "lint:ci": "pnpm cross-env CI=1 pnpm eslint --quiet .",
    "format": "pnpm prettier --write .",
    "format:check": "pnpm prettier --check .",
    "format:quick": "pnpm pretty-quick"
