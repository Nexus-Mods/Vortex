{
  "$schema": "https://www.schemastore.org/package.json",
  "name": "@vortex/monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017",
  "engines": {
    "node": "22"
  },
  "volta": {
    "node": "22.22.0",
    "yarn": "1.22.19"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build:fomod": "node ./preinstall.js",
    "start": "pnpm -F @vortex/main run start",
    "build": "pnpm --filter '@vortex/*' -r run build",
    "build:extensions": "pnpm --filter './extensions/**' run build",
    "dist": "pnpm --filter '@vortex/*' -r run dist",
    "dist:extensions": "pnpm --filter './extensions/**' run dist",
    "package": "pnpm run dist && pnpm run assets:dist && pnpm run dist:extensions && pnpm -F @vortex/main run package",
    "package:nosign": "pnpm run dist && pnpm run assets:dist && pnpm run dist:extensions && pnpm -F @vortex/main run package:nosign",
    "assets:out": "node ./InstallAssets.mjs ./src/main/out && pnpm sass --style compressed ./src/stylesheets/loadingScreen.scss ./src/main/out/assets/css/loadingScreen.css && pnpm tailwindcss -i ./src/stylesheets/tailwind-v4.css -o ./src/main/out/assets/css/tailwind-v4.css -m",
    "assets:dist": "node ./InstallAssets.mjs ./src/main/dist && pnpm sass --style compressed ./src/stylesheets/loadingScreen.scss ./src/main/dist/assets/css/loadingScreen.css && pnpm tailwindcss -i ./src/stylesheets/tailwind-v4.css -o ./src/main/dist/assets/css/tailwind-v4.css -m",
    "typecheck": "pnpm --filter '@vortex/*' -r run typecheck",
    "test": "pnpm --filter '@vortex/*' -r run test",
    "api": "pnpm -F @vortex/renderer run api:build && pnpm -F @vortex/renderer run api:docs",
    "lint": "pnpm eslint --cache --concurrency auto .",
    "lint:quiet": "pnpm eslint --cache --concurrency auto --quiet .",
    "lint:ci": "pnpm cross-env CI=1 pnpm eslint --quiet .",
    "format": "pnpm prettier --write .",
    "format:check": "pnpm prettier --check .",
    "format:quick": "pnpm pretty-quick"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "catalog:",
    "@eslint/js": "catalog:",
    "@microsoft/api-extractor": "catalog:",
    "@stylistic/eslint-plugin": "catalog:",
    "@tailwindcss/cli": "catalog:",
    "@types/copyfiles": "catalog:",
    "@types/minimist": "catalog:",
    "@types/node": "catalog:",
    "@types/webpack-node-externals": "catalog:",
    "@typescript-eslint/utils": "catalog:",
    "copyfiles": "catalog:",
    "cross-env": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-better-tailwindcss": "catalog:",
    "eslint-plugin-perfectionist": "catalog:",
    "fork-ts-checker-webpack-plugin": "catalog:",
    "glob": "catalog:",
    "globals": "catalog:",
    "minimist": "catalog:",
    "p-limit": "catalog:",
    "prettier": "catalog:",
    "pretty-quick": "catalog:",
    "rimraf": "catalog:",
    "sass": "catalog:",
    "tailwindcss": "catalog:",
    "terser-webpack-plugin": "catalog:",
    "ts-loader": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "webpack": "catalog:",
    "webpack-cli": "catalog:",
    "webpack-node-externals": "catalog:"
  },
  "pnpm": {
    "overrides": {
      "node-addon-api": "8.5.0",
      "@types/react": "16",
      "@types/react-dom": "16"
    }
  }
}
