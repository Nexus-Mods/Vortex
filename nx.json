{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "defaultBase": "master",
  "neverConnectToCloud": true,
  "analytics": false,
  "tui": {
    "autoExit": true
  },
  "namedInputs": {
    "default": [
      "{workspaceRoot}/pnpm-workspace.yaml",
      "{workspaceRoot}/pnpm-lock.yaml",
      "{workspaceRoot}/package.json",
      "{projectRoot}/package.json",
      { "env": "NODE_ENV" }
    ],
    "typescript": [
      "{workspaceRoot}/rolldown.base.mjs",
      "{workspaceRoot}/tsconfig*.json",
      "{projectRoot}/tsconfig*.json",
      "{projectRoot}/build.mjs",
      "{projectRoot}/tsdown.config.ts",
      "{projectRoot}/src/**/*.{ts,tsx}"
    ],
    "eslint": ["{projectRoot}/eslint.config.mjs", "{workspaceRoot}/eslint.config.base.mjs"],
    "vortex-api": [
      "{workspaceRoot}/scripts/extensions-rolldown.mjs",
      { "dependentTasksOutputFiles": "packages/vortex-api/lib/api.d.ts" }
    ]
  },
  "targetDefaults": {
    "build": {
      "dependsOn": ["^build"],
      "cache": true,
      "inputs": [
        "default",
        "typescript",
        "!{projectRoot}/src/**/*.test.{ts,tsx}",
        { "dependentTasksOutputFiles": "**/dist/**" }
      ],
      "outputs": ["{projectRoot}/dist/"]
    },
    "test*": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "cache": true,
      "inputs": ["default", "typescript"],
      "outputs": ["{projectRoot}/tsconfig*.tsbuildinfo"]
    },
    "lint*": {
      "dependsOn": ["^build"],
      "cache": true,
      "inputs": ["default", "typescript", "eslint"],
      "outputs": []
    }
  }
}
