{
  "name": "mtframework-arc-support",
  "version": "0.1.1",
  "description": "Support for arc archives used in MT Framework (Capcom) games",
  "scripts": {
    "build": "node build.mjs && node download_arctool.js && pnpm extractInfo",
    "typecheck": "pnpm tsc"
  },
  "author": "Black Tree Gaming Ltd.",
  "license": "GPL-3.0",
  "type": "commonjs",
  "private": true,
  "config": {
    "extensionName": "Capcom MT Framework arc Support"
  },
  "devDependencies": {
    "@types/bluebird": "catalog:",
    "@types/i18next": "catalog:",
    "@types/react": "catalog:",
    "@types/redux": "catalog:",
    "copyfiles": "catalog:",
    "node-7z": "catalog:",
    "react": "catalog:",
    "react-i18next": "catalog:",
    "shortid": "catalog:",
    "vortex-api": "workspace:*"
  },
  "nx": {
    "tags": [
      "vortex:extension"
    ],
    "targets": {
      "build": {
        "inputs": [
          "default",
          "typescript",
          "vortex-api"
        ]
      },
      "typecheck": {
        "inputs": [
          "default",
          "typescript",
          "vortex-api"
        ]
      }
    }
  }
}
