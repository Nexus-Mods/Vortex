{
  "name": "modtype-umm",
  "version": "1.0.4",
  "description": "Unity Mod Manager modtype to support Unity games which rely on UMM to install mods",
  "scripts": {
    "build": "pnpm generate-validation -t ./tsconfig.json && node build.mjs && pnpm extractInfo",
    "typecheck": "pnpm generate-validation -t ./tsconfig.json && pnpm tsc"
  },
  "author": "Black Tree Gaming Ltd.",
  "license": "GPL-3.0",
  "type": "commonjs",
  "private": true,
  "config": {
    "extensionName": "Mod Type: Unity Mod Manager (UMM)"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "@types/redux": "catalog:",
    "@types/semver": "catalog:",
    "bluebird": "catalog:",
    "copyfiles": "catalog:",
    "i18next": "catalog:",
    "react": "catalog:",
    "react-i18next": "catalog:",
    "redux": "catalog:",
    "semver": "catalog:",
    "vortex-api": "workspace:*",
    "winapi-bindings": "catalog:"
  },
  "dependencies": {
    "ts-v-gen": "catalog:"
  },
  "nx": {
    "tags": [
      "vortex:extension"
    ],
    "targets": {
      "build": {
        "inputs": [
          "default",
          "typescript",
          "vortex-api"
        ]
      },
      "typecheck": {
        "inputs": [
          "default",
          "typescript",
          "vortex-api"
        ]
      }
    }
  }
}
