{
  "name": "new-file-monitor",
  "version": "0.1.0",
  "description": "Generate events when new files are added to a mod directory",
  "scripts": {
    "_assets": "copyfiles -u 1 -f src/stylesheets/import-tool.scss src/images/* dist",
    "build": "node build.mjs && pnpm run _assets && pnpm extractInfo",
    "typecheck": "pnpm tsc"
  },
  "author": "Black Tree Gaming Ltd.",
  "license": "GPL-3.0",
  "devDependencies": {
    "@types/bluebird": "catalog:",
    "@types/node": "catalog:",
    "bluebird": "catalog:",
    "copyfiles": "catalog:",
    "redux": "catalog:",
    "turbowalk": "catalog:",
    "typescript": "catalog:",
    "vortex-api": "workspace:*"
  },
  "nx": {
    "tags": [
      "vortex:extension"
    ],
    "targets": {
      "build": {
        "inputs": [
          "default",
          "typescript",
          "vortex-api"
        ]
      },
      "typecheck": {
        "inputs": [
          "default",
          "typescript",
          "vortex-api"
        ]
      }
    }
  }
}
