{
  "name": "new-file-monitor",
  "version": "0.1.0",
  "description": "generate events when new files are added to a mod directory",
  "main": "./out/index.js",
  "scripts": {
    "webpack": "webpack --config webpack.config.js --progress --profile --color",
    "installDev": "copyfiles -f dist/* ../../out/bundledPlugins/new-file-monitor",
    "_build": "npm run webpack && copyfiles -f src/stylesheets/import-tool.scss dist && copyfiles -f src/images/* dist && extractInfo",
    "build": "npm run _build && copyfiles -u 1 dist/**/* ../../src/main/out/bundledPlugins/new-file-monitor",
    "buildDev": "npm run build && npm run installDev",
    "dist": "npm run _build && copyfiles -u 1 dist/**/* ../../src/main/dist/bundledPlugins/new-file-monitor"
  },
  "author": "Black Tree Gaming Ltd.",
  "license": "GPL-3.0",
  "devDependencies": {
    "@types/node": "catalog:",
    "copyfiles": "catalog:",
    "redux": "catalog:",
    "turbowalk": "catalog:",
    "typescript": "catalog:",
    "vortex-ext-dependencies": "catalog:",
    "bluebird": "catalog:",
    "@types/bluebird": "catalog:",
    "vortex-api": "catalog:"
  }
}
