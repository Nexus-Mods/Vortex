{
  "name": "new-file-monitor",
  "version": "0.1.0",
  "description": "generate events when new files are added to a mod directory",
  "main": "./out/index.js",
  "scripts": {
    "_assets": "copyfiles -u 1 -f src/stylesheets/import-tool.scss src/images/* dist",
    "_build": "pnpm webpack --config webpack.config.js --progress --profile --color && pnpm run _assets && extractInfo",
    "build": "pnpm run _build && node ../copy-extension.mjs new-file-monitor out",
    "dist": "pnpm run _build && node ../copy-extension.mjs new-file-monitor dist"
  },
  "author": "Black Tree Gaming Ltd.",
  "license": "GPL-3.0",
  "devDependencies": {
    "@types/node": "catalog:",
    "copyfiles": "catalog:",
    "redux": "catalog:",
    "turbowalk": "catalog:",
    "typescript": "catalog:",
    "vortex-ext-dependencies": "catalog:",
    "bluebird": "catalog:",
    "@types/bluebird": "catalog:",
    "vortex-api": "catalog:"
  }
}
