{
  "name": "gamebryo-bsa-support",
  "version": "0.1.0",
  "description": "Support for (old) gamebryo data archives",
  "main": "./out/index.js",
  "exports": {
    "node": "./out/index.js"
  },
  "scripts": {
    "_native": "node ../copy-native.mjs ./node_modules/bsatk/build/Release/bsatk.node",
    "_build": "node build.mjs && pnpm run _native && pnpm extractInfo",
    "build": "node -e \"if(process.platform==='win32')process.exit(1)\" || (pnpm run _build && node ../copy-extension.mjs out)",
    "dist": "node -e \"if(process.platform==='win32')process.exit(1)\" || (pnpm run _build && node ../copy-extension.mjs dist)"
  },
  "author": "Black Tree Gaming Ltd.",
  "license": "GPL-3.0",
  "devDependencies": {
    "@types/i18next": "catalog:",
    "@types/node": "catalog:",
    "@types/rimraf": "catalog:",
    "bluebird": "catalog:",
    "bsatk": "catalog:",
    "copyfiles": "catalog:",
    "rimraf": "catalog:",
    "tmp": "catalog:",
    "vortex-api": "workspace:*"
  }
}
