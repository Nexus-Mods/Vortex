{
  "name": "gamebryo-bsa-support",
  "version": "0.1.0",
  "description": "Support for (old) gamebryo data archives",
  "main": "./out/index.js",
  "exports": {
    "node": "./out/index.js"
  },
  "scripts": {
    "webpack": "webpack --config webpack.config.js --mode development --progress --profile --color",
    "copy_bsatk": "copyfiles -f ./node_modules/bsatk/build/Release/bsatk.node ./dist",
    "build": "node -e \"if(process.platform==='win32')process.exit(1)\" || npm run _build",
    "_build": "npm run webpack && npm run copy_bsatk && extractInfo"
  },
  "author": "Black Tree Gaming Ltd.",
  "license": "GPL-3.0",
  "devDependencies": {
    "@types/i18next": "catalog:",
    "@types/node": "catalog:",
    "@types/rimraf": "catalog:",
    "bluebird": "catalog:",
    "bsatk": "catalog:",
    "copyfiles": "catalog:",
    "rimraf": "catalog:",
    "tmp": "catalog:",
    "ts-loader": "catalog:",
    "vortex-api": "catalog:",
    "webpack": "catalog:",
    "webpack-cli": "catalog:"
  }
}
