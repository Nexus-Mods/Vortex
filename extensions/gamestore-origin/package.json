{
  "name": "gamestore-origin",
  "version": "0.1.0",
  "description": "Discovery and game launch support for the Origin/EA game store",
  "scripts": {
    "build": "node build.mjs && pnpm extractInfo",
    "typecheck": "pnpm tsc"
  },
  "author": "Black Tree Gaming Ltd.",
  "license": "GPL-3.0",
  "type": "commonjs",
  "private": true,
  "config": {
    "extensionName": "Game Store: Origin/EA"
  },
  "devDependencies": {
    "@types/bluebird": "catalog:",
    "@types/libxmljs": "catalog:",
    "bluebird": "catalog:",
    "copyfiles": "catalog:",
    "turbowalk": "catalog:",
    "typescript": "catalog:",
    "vortex-api": "workspace:*",
    "winapi-bindings": "catalog:",
    "xml2js": "catalog:"
  },
  "nx": {
    "tags": [
      "vortex:extension"
    ],
    "targets": {
      "build": {
        "inputs": [
          "default",
          "typescript",
          "vortex-api"
        ]
      },
      "typecheck": {
        "inputs": [
          "default",
          "typescript",
          "vortex-api"
        ]
      }
    }
  }
}
