{
  "name": "meta-editor",
  "version": "0.0.1",
  "description": "Editor for Mod Meta Data",
  "main": "./out/index.js",
  "repository": "",
  "scripts": {
    "webpack": "node ./node_modules/webpack/bin/webpack --config webpack.config.js --progress --profile --color",
    "installDev": "copyfiles -f dist/* ../../out/bundledPlugins/meta-editor",
    "_build": "npm run webpack && copyfiles -f src/stylesheets/metaeditor.scss dist && extractInfo",
    "build": "npm run _build && copyfiles -u 1 dist/**/* ../../src/main/out/bundledPlugins/meta-editor",
    "buildDev": "npm run build && npm run installDev",
    "dist": "npm run _build && copyfiles -u 1 dist/**/* ../../src/main/dist/bundledPlugins/meta-editor"
  },
  "author": "Black Tree Gaming Ltd.",
  "license": "GPL-3.0",
  "babel": {
    "presets": [
      "es2015"
    ]
  },
  "devDependencies": {
    "@babel/core": "catalog:",
    "@types/immutability-helper": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-bootstrap": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/react-redux": "catalog:",
    "@types/react-router": "catalog:",
    "babel-loader": "catalog:",
    "babel-polyfill": "catalog:",
    "bluebird": "catalog:",
    "copyfiles": "catalog:",
    "i18next": "catalog:",
    "immutability-helper": "catalog:",
    "json-loader": "catalog:",
    "modmeta-db": "catalog:",
    "react": "catalog:",
    "react-i18next": "catalog:",
    "semver": "catalog:",
    "ts-loader": "catalog:",
    "vortex-api": "catalog:",
    "webpack": "catalog:",
    "webpack-cli": "catalog:",
    "redux-act": "catalog:"
  }
}
