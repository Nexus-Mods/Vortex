{
  "name": "meta-editor",
  "version": "0.0.1",
  "description": "Editor for Mod Meta Data",
  "scripts": {
    "_assets": "copyfiles -u 1 -f src/stylesheets/metaeditor.scss dist",
    "build": "node build.mjs && pnpm run _assets && pnpm extractInfo",
    "typecheck": "pnpm tsc"
  },
  "author": "Black Tree Gaming Ltd.",
  "license": "GPL-3.0",
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-bootstrap": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/react-redux": "catalog:",
    "@types/react-router": "catalog:",
    "bluebird": "catalog:",
    "copyfiles": "catalog:",
    "i18next": "catalog:",
    "immutability-helper": "catalog:",
    "json-loader": "catalog:",
    "modmeta-db": "catalog:",
    "react": "catalog:",
    "react-i18next": "catalog:",
    "redux-act": "catalog:",
    "semver": "catalog:",
    "vortex-api": "workspace:*"
  },
  "nx": {
    "tags": [
      "vortex:extension"
    ],
    "targets": {
      "build": {
        "inputs": [
          "default",
          "typescript",
          "vortex-api"
        ]
      },
      "typecheck": {
        "inputs": [
          "default",
          "typescript",
          "vortex-api"
        ]
      }
    }
  }
}
