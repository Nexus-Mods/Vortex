{
  "name": "mod-content",
  "version": "0.2.4",
  "description": "Add mod column indicating the content it contains",
  "scripts": {
    "_assets": "copyfiles -u 1 -f src/icons.svg src/mod-content.scss dist",
    "_build": "node build.mjs && pnpm run _assets && pnpm extractInfo",
    "build": "pnpm run _build && node ../copy-extension.mjs out",
    "dist": "pnpm run _build && node ../copy-extension.mjs dist",
    "typecheck": "pnpm tsc"
  },
  "author": "Black Tree Gaming Ltd.",
  "license": "GPL-3.0",
  "devDependencies": {
    "7z-bin": "catalog:",
    "@types/i18next": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-bootstrap": "catalog:",
    "@types/react-redux": "catalog:",
    "@types/redux": "catalog:",
    "@types/redux-thunk": "catalog:",
    "bluebird": "catalog:",
    "copyfiles": "catalog:",
    "i18next": "catalog:",
    "react": "catalog:",
    "react-bootstrap": "catalog:",
    "redux": "catalog:",
    "turbowalk": "catalog:",
    "vortex-api": "workspace:*"
  }
}
