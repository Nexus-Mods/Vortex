{
  "name": "gameversion-hash",
  "version": "1.0.2",
  "description": "An alternative to conventional game version resolution aiming to identify game version based on file hashes. This is useful when the game is in Early Access or the user facing version is not easily resolved.",
  "main": "./dist/index.js",
  "scripts": {
    "_build": "pnpm webpack --config webpack.config.js --progress --profile --color && extractInfo",
    "build": "pnpm run _build && node ../copy-extension.mjs gameversion-hash out",
    "dist": "pnpm run _build && node ../copy-extension.mjs gameversion-hash dist"
  },
  "author": "Black Tree Gaming Ltd.",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-bootstrap": "catalog:",
    "@types/redux": "catalog:",
    "@types/redux-thunk": "catalog:",
    "copyfiles": "catalog:",
    "react": "catalog:",
    "react-bootstrap": "catalog:",
    "react-dom": "catalog:",
    "typescript": "catalog:",
    "vortex-ext-dependencies": "catalog:",
    "vortexmt": "catalog:",
    "webpack": "catalog:",
    "webpack-cli": "catalog:",
    "vortex-api": "catalog:"
  },
  "dependencies": {
    "simple-git": "catalog:"
  }
}
