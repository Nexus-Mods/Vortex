{
  "name": "theme-switcher",
  "version": "0.1.0",
  "description": "Settings section to switch and customize UI themes",
  "main": "./out/index.js",
  "scripts": {
    "_assets": "copyfiles -u 1 -u 3 themes/**/* dist",
    "_native": "node ../copy-native.mjs -u 4 ./node_modules/font-scanner/build/Release/fontmanager.node",
    "_build": "node build.mjs && pnpm run _assets && pnpm run _native && extractInfo",
    "build": "pnpm run _build && node ../copy-extension.mjs theme-switcher out",
    "dist": "pnpm run _build && node ../copy-extension.mjs theme-switcher dist"
  },
  "author": "Black Tree Gaming Ltd.",
  "license": "GPL-3.0",
  "devDependencies": {
    "@types/bluebird": "catalog:",
    "@types/react": "catalog:",
    "@types/react-bootstrap": "catalog:",
    "@types/react-color": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/react-redux": "catalog:",
    "@types/redux": "catalog:",
    "@types/redux-thunk": "catalog:",
    "bluebird": "catalog:",
    "copyfiles": "catalog:",
    "font-scanner": "catalog:",
    "i18next": "catalog:",
    "prop-types": "catalog:",
    "react": "catalog:",
    "react-bootstrap": "catalog:",
    "react-color": "catalog:",
    "react-dom": "catalog:",
    "react-i18next": "catalog:",
    "redux": "catalog:",
    "redux-act": "catalog:",
    "redux-thunk": "catalog:",
    "vortex-api": "catalog:"
  }
}
