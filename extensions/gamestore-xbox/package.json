{
  "name": "gamestore-xbox",
  "version": "0.2.3",
  "description": "Provides discovery and launch support for Microsoft Store (XBox pass) games",
  "main": "./out/index.js",
  "repository": "",
  "scripts": {
    "_build": "pnpm webpack --config webpack.config.js --progress --profile --color && extractInfo",
    "build": "node -e \"if(process.platform==='win32')process.exit(1)\" || (pnpm run _build && node ../copy-extension.mjs gamestore-xbox out)",
    "dist": "node -e \"if(process.platform==='win32')process.exit(1)\" || (pnpm run _build && node ../copy-extension.mjs gamestore-xbox dist)"
  },
  "author": "Black Tree Gaming Ltd.",
  "license": "GPL-3.0",
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vortex-ext-dependencies": "catalog:",
    "winapi-bindings": "catalog:",
    "xml2js": "catalog:",
    "turbowalk": "catalog:",
    "@types/redux": "catalog:",
    "redux-thunk": "catalog:",
    "redux": "catalog:",
    "vortex-api": "catalog:",
    "webpack": "catalog:",
    "webpack-cli": "catalog:",
    "copyfiles": "catalog:"
  }
}
