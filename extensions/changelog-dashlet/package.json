{
  "name": "changelog-dashlet",
  "version": "0.0.5",
  "description": "Shows the changelog of the current vortex version on the dashlet",
  "main": "./out/index.js",
  "repository": "",
  "scripts": {
    "webpack": "webpack --config webpack.config.js --progress --profile --color",
    "copy_scss": "copyfiles -f src/changelog.scss dist",
    "build": "npm run webpack && npm run copy_scss && extractInfo"
  },
  "author": "Black Tree Gaming Ltd.",
  "license": "GPL-3.0",
  "babel": {
    "presets": [
      "es2015"
    ]
  },
  "devDependencies": {
    "@babel/core": "catalog:",
    "@types/bluebird": "catalog:",
    "@types/react": "catalog:",
    "@types/react-bootstrap": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/redux": "catalog:",
    "@types/redux-thunk": "catalog:",
    "@types/semver": "catalog:",
    "copyfiles": "catalog:",
    "react-redux": "catalog:",
    "redux-act": "catalog:",
    "semver": "catalog:",
    "vortex-ext-dependencies": "Nexus-Mods/vortex-ext-dependencies",
    "lodash": "catalog:",
    "react-i18next": "catalog:",
    "react-markdown": "catalog:",
    "webpack": "catalog:",
    "webpack-cli": "catalog:",
    "redux": "catalog:",
    "vortex-api": "git+https://github.com/Nexus-Mods/vortex-api"
  }
}
