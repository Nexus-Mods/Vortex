{
  "name": "mod-report",
  "description": "Create a report on the final effects of a mod on disk",
  "version": "0.0.7",
  "main": "./out/index.js",
  "license": "GPL-3.0",
  "author": "Black Tree Gaming Ltd.",
  "scripts": {
    "webpack": "node ./node_modules/webpack/bin/webpack --config webpack.config.js --progress --profile --color",
    "_build": "npm run webpack && extractInfo",
    "build": "npm run _build && copyfiles -u 1 dist/**/* ../../src/main/out/bundledPlugins/mod-report",
    "dist": "npm run _build && copyfiles -u 1 dist/**/* ../../src/main/dist/bundledPlugins/mod-report"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "bs58": "catalog:",
    "electron": "catalog:",
    "fork-ts-checker-webpack-plugin": "catalog:",
    "ts-loader": "catalog:",
    "turbowalk": "catalog:",
    "typescript": "catalog:",
    "vortex-api": "catalog:",
    "webpack": "catalog:",
    "webpack-cli": "catalog:",
    "copyfiles": "catalog:"
  }
}
