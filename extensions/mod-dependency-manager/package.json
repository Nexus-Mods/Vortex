  "version": "0.3.0",
  "description": "Control mod dependencies through drag&drop",
  "main": "./out/index.js",
  "repository": "",
  "scripts": {
    "_assets": "copyfiles -u 1 -f src/stylesheets/*.scss src/language.json dist",
    "_build": "node build.mjs && pnpm run _assets && extractInfo",
