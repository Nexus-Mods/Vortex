{
  "name": "mod-dependency-manager",
  "version": "0.3.0",
  "description": "Control mod dependencies through drag&drop",
  "main": "./out/index.js",
  "repository": "",
  "scripts": {
    "webpack": "webpack --config webpack.config.js --progress --profile --color",
    "installDev": "copyfiles -f dist/* ../../out/bundledPlugins/mod-dependency-manager",
    "build": "npm run webpack && copyfiles -f src/stylesheets/*.scss dist && copyfiles -f src/language.json dist && extractInfo",
    "buildDev": "npm run build && npm run installDev"
  },
