{
  "name": "test-gameversion",
  "version": "0.1.1",
  "description": "Report an error if a mod isn't compatible with the current game version",
  "scripts": {
    "build": "node build.mjs && pnpm extractInfo",
    "typecheck": "pnpm tsc"
  },
  "author": "Black Tree Gaming Ltd.",
  "license": "GPL-3.0",
  "devDependencies": {
    "@types/i18next": "catalog:",
    "@types/redux": "catalog:",
    "bluebird": "catalog:",
    "copyfiles": "catalog:",
    "exe-version": "workspace:*",
    "i18next": "catalog:",
    "immutability-helper": "catalog:",
    "json-loader": "catalog:",
    "react": "catalog:",
    "react-bootstrap": "catalog:",
    "react-dom": "catalog:",
    "react-i18next": "catalog:",
    "redux-act": "catalog:",
    "redux-thunk": "catalog:",
    "vortex-api": "workspace:*",
    "vortex-parse-ini": "catalog:"
  },
  "nx": {
    "tags": [
      "vortex:extension"
    ],
    "targets": {
      "build": {
        "inputs": [
          "default",
          "typescript",
          "vortex-api"
        ]
      },
      "typecheck": {
        "inputs": [
          "default",
          "typescript",
          "vortex-api"
        ]
      }
    }
  }
}
