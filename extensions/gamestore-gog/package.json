{
  "name": "gamestore-gog",
  "version": "0.0.5",
  "description": "Provides discovery and launch support for GoG games",
  "main": "./out/index.js",
  "repository": "",
  "scripts": {
    "webpack": "webpack --config webpack.config.js --progress --profile --color",
    "_build": "npm run webpack && extractInfo",
