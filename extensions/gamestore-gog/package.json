    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vortex-ext-dependencies": "catalog:",
    "webpack": "catalog:",
    "webpack-cli": "catalog:",
    "winapi-bindings": "catalog:",
    "bluebird": "catalog:",
    "@types/bluebird": "catalog:",
    "vortex-api": "catalog:",
    "copyfiles": "catalog:"
  }
}
