    "@types/react-dom": "catalog:",
    "@types/redux": "catalog:",
    "@types/redux-thunk": "catalog:",
    "@types/semver": "catalog:",
    "babel-core": "catalog:",
    "babel-loader": "catalog:",
    "copyfiles": "catalog:",
    "react-dnd": "catalog:",
    "react-redux": "catalog:",
    "redux-act": "catalog:",
    "semver": "catalog:",
    "typescript": "catalog:",
    "vortex-ext-dependencies": "catalog:",
    "react-i18next": "catalog:",
    "webpack": "catalog:",
    "webpack-cli": "catalog:",
