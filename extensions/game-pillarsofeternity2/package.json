{
  "name": "game-pillarsofeternity2",
  "version": "0.2.2",
  "description": "Vortex support for Pillars Of Eternity 2: Deadfire",
  "main": "./out/index.js",
  "repository": "",
  "scripts": {
    "_assets": "copyfiles -u 1 -f assets/gameart.png src/stylesheet.scss dist",
    "_build": "pnpm webpack --config webpack.config.js --progress --profile --color && pnpm run _assets && extractInfo",
    "build": "pnpm run _build && node ../copy-extension.mjs game-pillarsofeternity2 out",
    "dist": "pnpm run _build && node ../copy-extension.mjs game-pillarsofeternity2 dist"
  },
  "author": "Black Tree Gaming Ltd.",
  "license": "GPL-3.0",
  "babel": {
    "presets": [
      "es2015"
    ]
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-bootstrap": "catalog:",
