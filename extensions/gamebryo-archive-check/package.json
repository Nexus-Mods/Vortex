{
  "name": "gamebryo-archive-check",
  "version": "1.0.5",
  "description": "Check BSA/BA2 archives are valid for the current game after updating your load order.",
  "scripts": {
    "_build": "node build.mjs && pnpm extractInfo",
    "build": "pnpm run _build && node ../copy-extension.mjs out",
    "dist": "pnpm run _build && node ../copy-extension.mjs dist"
  },
  "author": "Pickysaurus",
  "license": "GPL-3.0",
  "devDependencies": {
    "@types/bluebird": "catalog:",
    "@types/i18next": "catalog:",
    "@types/node": "catalog:",
    "@types/redux": "catalog:",
    "@types/redux-thunk": "catalog:",
    "bluebird": "catalog:",
    "copyfiles": "catalog:",
    "react-bootstrap": "catalog:",
    "typescript": "catalog:",
    "vortex-api": "workspace:*"
  }
}
