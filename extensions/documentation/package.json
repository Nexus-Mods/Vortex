{
  "name": "documentation",
  "version": "1.0.1",
  "description": "In-Application documentation and tutorial videos",
  "scripts": {
    "_assets": "copyfiles -u 1 -f src/stylesheets/*.scss dist",
    "build": "node build.mjs && pnpm run _assets && pnpm extractInfo",
    "typecheck": "pnpm tsc"
  },
  "author": "Black Tree Gaming Ltd.",
  "license": "GPL-3.0",
  "devDependencies": {
    "@types/lodash": "catalog:",
    "@types/react": "catalog:",
    "@types/react-redux": "catalog:",
    "copyfiles": "catalog:",
    "i18next": "catalog:",
    "lodash": "catalog:",
    "react-bootstrap": "catalog:",
    "react-dom": "catalog:",
    "react-i18next": "catalog:",
    "redux": "catalog:",
    "redux-act": "catalog:",
    "vortex-api": "workspace:*"
  },
  "nx": {
    "tags": [
      "vortex:extension"
    ],
    "targets": {
      "build": {
        "inputs": [
          "default",
          "typescript",
          "vortex-api"
        ]
      },
      "typecheck": {
        "inputs": [
          "default",
          "typescript",
          "vortex-api"
        ]
      }
    }
  }
}
