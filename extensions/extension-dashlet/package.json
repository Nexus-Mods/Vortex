    "@types/react-bootstrap": "catalog:",
    "@types/react-redux": "catalog:",
    "copyfiles": "catalog:",
    "i18next": "catalog:",
    "react-i18next": "catalog:",
    "redux": "catalog:",
    "redux-thunk": "catalog:",
    "turbowalk": "catalog:",
    "typescript": "catalog:",
    "vortex-ext-dependencies": "catalog:",
    "memoize-one": "catalog:",
    "vortex-api": "catalog:"
  }
}
