{
  "name": "extensions-dashlet",
  "version": "0.0.3",
  "description": "Dashlet to advertise newly released dashlets and remind user to endorse",
  "main": "./out/index.js",
  "scripts": {
    "webpack": "webpack --config webpack.config.js --progress --profile --color",
    "_build": "npm run webpack && copyfiles -f src/extensions-dashlet.scss dist && extractInfo",
    "build": "npm run _build && node ../copy-extension.mjs extension-dashlet out",
    "dist": "npm run _build && node ../copy-extension.mjs extension-dashlet dist"
  },
