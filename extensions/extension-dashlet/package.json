{
  "name": "extensions-dashlet",
  "version": "0.0.3",
  "description": "Dashlet to advertise newly released dashlets and remind user to endorse",
  "main": "./out/index.js",
  "scripts": {
    "_assets": "copyfiles -u 1 -f src/extensions-dashlet.scss dist",
    "_build": "node build.mjs && pnpm run _assets && pnpm extractInfo",
    "build": "pnpm run _build && node ../copy-extension.mjs out",
    "dist": "pnpm run _build && node ../copy-extension.mjs dist"
  },
  "author": "Black Tree Gaming Ltd.",
  "license": "GPL-3.0",
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-bootstrap": "catalog:",
    "@types/react-redux": "catalog:",
    "copyfiles": "catalog:",
    "i18next": "catalog:",
    "memoize-one": "catalog:",
    "react-i18next": "catalog:",
    "redux": "catalog:",
    "redux-thunk": "catalog:",
    "turbowalk": "catalog:",
    "typescript": "catalog:",
    "vortex-api": "workspace:*"
  }
}
