{
  "name": "collections",
  "description": "Allows creation of installation of mod packs (meta mods that install a bunch of other mods)",
  "version": "0.2.2",
  "main": "./out/index.js",
  "license": "GPL-3.0",
  "author": "Black Tree Gaming Ltd.",
  "scripts": {
    "webpack": "node ./node_modules/webpack/bin/webpack --config webpack.config.js --progress --profile --color",
    "copy_assets": "copyfiles -f src/language.json dist && copyfiles -f src/icons.svg dist && copyfiles -f src/collectionicon.svg dist && copyfiles -f style.scss dist && copyfiles -f src/assets/fallback_tile.png dist && copyfiles -f node_modules/bsdiff-node/build/Release/bsdiff.node dist",
    "bundle7z": "7z a -t7z collections.7z .\\dist\\index.js .\\dist\\info.json .\\dist\\language.json .\\dist\\*.svg .\\dist\\style.scss",
    "update_validation": "generate-validation .",
    "_postinstall": "npm run update_validation",
    "build": "npm run webpack && npm run copy_assets && extractInfo",
    "test": "jest",
    "test:build": "node scripts/validate-build.js"
  },
  "devDependencies": {
    "7z-bin": "catalog:",
