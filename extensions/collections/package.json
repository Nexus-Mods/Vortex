{
  "name": "collections",
  "description": "Allows creation of installation of mod packs (meta mods that install a bunch of other mods)",
  "version": "0.2.2",
  "license": "GPL-3.0",
  "author": "Black Tree Gaming Ltd.",
  "scripts": {
    "_assets": "copyfiles -u 1 -f src/language.json src/icons.svg src/collectionicon.svg style.scss src/assets/fallback_tile.png dist",
    "_wasm": "node -e \"require('fs').copyFileSync(require('path').resolve(process.cwd(),'node_modules/@hot-updater/bsdiff/assets/hdiff.wasm'), require('path').resolve(process.cwd(),'dist/hdiff.wasm'))\"",
    "build": "node build.mjs && pnpm run _assets && pnpm run _wasm && pnpm extractInfo",
    "typecheck": "pnpm tsc"
  },
  "devDependencies": {
    "7z-bin": "catalog:",
    "@hot-updater/bsdiff": "catalog:",
    "@nexusmods/nexus-api": "catalog:",
    "@types/lodash": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-bootstrap": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/react-redux": "catalog:",
    "@types/redux": "catalog:",
    "bluebird": "catalog:",
    "copyfiles": "catalog:",
    "crc-32": "catalog:",
    "i18next": "catalog:",
    "lodash": "catalog:",
    "memoize-one": "catalog:",
    "modmeta-db": "catalog:",
    "node-7z": "catalog:",
    "react": "catalog:",
    "react-bootstrap": "catalog:",
    "react-dom": "catalog:",
    "react-i18next": "catalog:",
    "react-markdown": "catalog:",
    "react-redux": "catalog:",
    "react-select": "catalog:",
    "redux": "catalog:",
    "redux-act": "catalog:",
    "redux-thunk": "catalog:",
    "reselect": "catalog:",
    "semver": "catalog:",
    "shortid": "catalog:",
    "tmp": "catalog:",
    "ts-v-gen": "catalog:",
    "turbowalk": "catalog:",
    "typescript": "catalog:",
    "vortex-api": "workspace:*"
  },
  "nx": {
    "tags": [
      "vortex:extension"
    ],
    "targets": {
      "build": {
        "inputs": [
          "default",
          "typescript",
          "vortex-api"
        ]
      },
      "typecheck": {
        "inputs": [
          "default",
          "typescript",
          "vortex-api"
        ]
      }
    }
  }
}
