{
  "name": "gamebryo-plugin-management",
  "version": "0.5.2",
  "description": "Management for gamebryo plugins",
  "main": "./out/index.js",
  "repository": "",
  "scripts": {
    "_assets": "copyfiles -u 1 -f src/stylesheets/plugin_management.scss src/language.json dist",
    "_native": "copyfiles -u 1 -f ./node_modules/esptk/build/Release/esptk.node ./node_modules/loot/build/Release/node-loot.node ./node_modules/loot/loot_api/loot.dll ./node_modules/loot/async.js ./node_modules/loot/bindings.js src/loot_icon.png dist && node -e \"const fs=require('fs');const f='dist/async.js';let c=fs.readFileSync(f,'utf8');c=c.replace('./build/Release/node-loot','./node-loot');fs.writeFileSync(f,c);\"",
    "_build": "pnpm webpack --config webpack.config.js --progress --profile --color && pnpm run _assets && pnpm run _native && extractInfo",
    "build": "node -e \"if(process.platform==='win32')process.exit(1)\" || (pnpm run _build && node ../copy-extension.mjs gamebryo-plugin-management out)",
    "dist": "node -e \"if(process.platform==='win32')process.exit(1)\" || (pnpm run _build && node ../copy-extension.mjs gamebryo-plugin-management dist)"
  },
  "author": "Black Tree Gaming Ltd.",
  "license": "GPL-3.0",
