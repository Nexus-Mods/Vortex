    "cytoscape-cose-bilkent": "catalog:",
    "cytoscape-edgehandles": "catalog:",
    "i18next": "catalog:",
    "immutability-helper": "catalog:",
    "js-yaml": "catalog:",
    "json-loader": "catalog:",
    "markdown-ast": "catalog:",
    "memoize-one": "catalog:",
    "lodash": "catalog:",
    "prop-types": "catalog:",
    "react": "catalog:",
    "react-dnd": "catalog:",
    "react-dom": "catalog:",
    "react-i18next": "catalog:",
