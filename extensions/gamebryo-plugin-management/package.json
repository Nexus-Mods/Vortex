{
  "name": "gamebryo-plugin-management",
  "version": "0.5.2",
  "description": "Management for gamebryo plugins",
  "main": "./out/index.js",
  "repository": "",
  "scripts": {
    "webpack": "webpack --config webpack.config.js --progress --profile --color",
    "copy_esptk": "copyfiles -f ./node_modules/esptk/build/Release/esptk.node ./dist",
    "copy_loot": "copyfiles -f ./node_modules/loot/build/Release/node-loot.node ./dist && copyfiles -f ./node_modules/loot/loot_api/loot.dll ./dist && copyfiles -f ./src/loot_icon.png ./dist",
    "copy_async": "copyfiles -f ./node_modules/loot/async.js ./dist && copyfiles -f ./node_modules/loot/bindings.js ./dist",
    "fix_async_path": "node -e \"const fs=require('fs');const f='dist/async.js';let c=fs.readFileSync(f,'utf8');c=c.replace('./build/Release/node-loot','./node-loot');fs.writeFileSync(f,c);\"",
    "copy_assets": "copyfiles -f src/stylesheets/plugin_management.scss dist && copyfiles -f src/language.json dist",
    "build": "node -e \"if(process.platform==='win32')process.exit(1)\" || npm run _build",
    "_build": "npm run webpack && npm run copy_esptk && npm run copy_loot && npm run copy_async && npm run fix_async_path && npm run copy_assets && extractInfo && copyfiles -u 1 dist/**/* ../../src/main/out/bundledPlugins/gamebryo-plugin-management",
    "installDev": "copyfiles -u 1 dist/**/* ../../out/bundledPlugins/gamebryo-plugin-management",
    "buildDev": "npm run build && npm run installDev",
    "_dist": "npm run webpack && npm run copy_esptk && npm run copy_loot && npm run copy_async && npm run fix_async_path && npm run copy_assets && extractInfo && copyfiles -u 1 dist/**/* ../../src/main/dist/bundledPlugins/gamebryo-plugin-management",
    "dist": "node -e \"if(process.platform==='win32')process.exit(1)\" || npm run _dist"
  },
  "author": "Black Tree Gaming Ltd.",
  "license": "GPL-3.0",
  "devDependencies": {
    "@types/cytoscape": "catalog:",
    "@types/js-yaml": "catalog:",
    "@types/react": "catalog:",
    "@types/react-bootstrap": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/react-faux-dom": "catalog:",
    "@types/react-redux": "catalog:",
    "@types/react-router": "catalog:",
    "@types/react-select": "catalog:",
    "@types/redux": "catalog:",
    "@types/redux-thunk": "catalog:",
    "bluebird": "catalog:",
    "copyfiles": "catalog:",
    "cytoscape": "catalog:",
    "cytoscape-cose-bilkent": "catalog:",
    "cytoscape-edgehandles": "catalog:",
    "i18next": "catalog:",
    "immutability-helper": "catalog:",
    "js-yaml": "catalog:",
    "json-loader": "catalog:",
    "markdown-ast": "catalog:",
    "memoize-one": "catalog:",
    "lodash": "catalog:",
    "prop-types": "catalog:",
    "react": "catalog:",
    "react-dnd": "catalog:",
    "react-dom": "catalog:",
    "react-i18next": "catalog:",
    "react-select": "catalog:",
    "redux": "catalog:",
    "redux-act": "catalog:",
    "redux-thunk": "catalog:",
    "ts-loader": "catalog:",
    "vortex-api": "catalog:",
    "webpack": "catalog:",
    "webpack-cli": "catalog:",
    "react-markdown": "catalog:",
    "reselect": "catalog:",
    "shortid": "catalog:",
    "electron": "catalog:",
    "react-dnd-html5-backend": "catalog:",
    "exe-version": "catalog:",
    "date-fns": "catalog:"
  },
  "optionalDependencies": {
    "loot": "catalog:",
    "esptk": "catalog:"
  }
}
