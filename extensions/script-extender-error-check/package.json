{
  "name": "script-extender-error-check",
  "version": "0.1.1",
  "description": "Warn if the script extender log contains error message",
  "scripts": {
    "_assets": "copyfiles -u 1 -f src/style.scss dist",
    "_build": "node build.mjs && pnpm run _assets && pnpm extractInfo",
    "build": "pnpm run _build && node ../copy-extension.mjs out",
    "dist": "pnpm run _build && node ../copy-extension.mjs dist"
  },
  "author": "Black Tree Gaming Ltd.",
  "license": "GPL-3.0",
  "devDependencies": {
    "7z-bin": "catalog:",
    "@types/i18next": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/redux": "catalog:",
    "@types/redux-thunk": "catalog:",
    "copyfiles": "catalog:",
    "i18next": "catalog:",
    "react": "catalog:",
    "react-bootstrap": "catalog:",
    "turbowalk": "catalog:",
    "vortex-api": "workspace:*"
  }
}
