{
  "name": "script-extender-error-check",
  "version": "0.1.1",
  "description": "Warn if the script extender log contains error messages",
  "scripts": {
    "_assets": "copyfiles -u 1 -f src/style.scss dist",
    "build": "node build.mjs && pnpm run _assets && pnpm extractInfo",
    "typecheck": "pnpm tsc"
  },
  "author": "Black Tree Gaming Ltd.",
  "license": "GPL-3.0",
  "devDependencies": {
    "7z-bin": "catalog:",
    "@types/i18next": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/redux": "catalog:",
    "@types/redux-thunk": "catalog:",
    "copyfiles": "catalog:",
    "i18next": "catalog:",
    "react": "catalog:",
    "react-bootstrap": "catalog:",
    "turbowalk": "catalog:",
    "vortex-api": "workspace:*"
  },
  "nx": {
    "tags": [
      "vortex:extension"
    ],
    "targets": {
      "build": {
        "inputs": [
          "default",
          "typescript",
          "vortex-api"
        ]
      },
      "typecheck": {
        "inputs": [
          "default",
          "typescript",
          "vortex-api"
        ]
      }
    }
  }
}
