{
  "name": "modtype-bepinex",
  "version": "0.2.9",
  "description": "Adds several BepInEx specific modTypes and the ability to automatically download and install the library.",
  "scripts": {
    "_assets": "copyfiles -u 1 -f src/assets/* dist",
    "_build": "node build.mjs && pnpm extractInfo && pnpm run _assets",
    "build": "pnpm run _build && node ../copy-extension.mjs out",
    "dist": "pnpm run _build && node ../copy-extension.mjs dist"
  },
  "author": "Black Tree Gaming Ltd.",
  "license": "GPL-3.0",
  "devDependencies": {
    "@types/i18next": "catalog:",
    "@types/react": "catalog:",
    "@types/redux": "catalog:",
    "@types/semver": "catalog:",
    "bluebird": "catalog:",
    "copyfiles": "catalog:",
    "i18next": "catalog:",
    "lodash": "catalog:",
    "react": "catalog:",
    "react-i18next": "catalog:",
    "semver": "catalog:",
    "vortex-api": "workspace:*",
    "vortex-parse-ini": "catalog:"
  },
  "dependencies": {
    "@iarna/toml": "catalog:"
  }
}
