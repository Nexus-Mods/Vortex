  "description": "Adds several BepInEx specific modTypes and the ability to automatically download and install the library.",
  "main": "./out/index.js",
  "repository": "",
  "scripts": {
    "_assets": "copyfiles -u 1 -f src/assets/* dist",
    "_build": "node build.mjs && extractInfo && pnpm run _assets",
    "build": "pnpm run _build && node ../copy-extension.mjs modtype-bepinex out",
    "dist": "pnpm run _build && node ../copy-extension.mjs modtype-bepinex dist"
  },
