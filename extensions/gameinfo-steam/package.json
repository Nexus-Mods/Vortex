{
  "name": "gameinfo-steam",
  "version": "0.0.1",
  "description": "Retrieve information about supported games from Steam",
  "scripts": {
    "build": "node build.mjs && pnpm extractInfo",
    "typecheck": "pnpm tsc"
  },
  "author": "Black Tree Gaming Ltd.",
  "license": "GPL-3.0",
  "type": "commonjs",
  "private": true,
  "config": {
    "extensionName": "Game Store: Steam"
  },
  "devDependencies": {
    "@types/redux": "catalog:",
    "bluebird": "catalog:",
    "copyfiles": "catalog:",
    "i18next": "catalog:",
    "react": "catalog:",
    "react-bootstrap": "catalog:",
    "react-dom": "catalog:",
    "react-i18next": "catalog:",
    "vortex-api": "workspace:*"
  },
  "nx": {
    "tags": [
      "vortex:extension"
    ],
    "targets": {
      "build": {
        "inputs": [
          "default",
          "typescript",
          "vortex-api"
        ]
      },
      "typecheck": {
        "inputs": [
          "default",
          "typescript",
          "vortex-api"
        ]
      }
    }
  }
}
