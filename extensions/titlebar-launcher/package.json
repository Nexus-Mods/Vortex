{
  "name": "titlebar-launcher",
  "version": "1.0.6",
  "description": "adds a launcher bar on the titlebar",
  "main": "./out/index.js",
  "vortex": {
    "version": ">=1.2.0"
  },
  "scripts": {
    "_assets": "copyfiles -u 1 -f titlebar-launcher.scss src/images/* dist",
    "_build": "pnpm webpack --config webpack.config.js --progress --profile --color && pnpm run _assets && extractInfo",
    "build": "pnpm run _build && node ../copy-extension.mjs titlebar-launcher out",
    "dist": "pnpm run _build && node ../copy-extension.mjs titlebar-launcher dist"
  },
  "author": "Black Tree Gaming Ltd.",
  "license": "GPL-3.0",
  "devDependencies": {
    "7z-bin": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-bootstrap": "catalog:",
    "copyfiles": "catalog:",
    "memoize-one": "catalog:",
    "react-redux": "catalog:",
    "redux": "catalog:",
    "typescript": "catalog:",
    "vortex-ext-dependencies": "catalog:",
    "redux-act": "catalog:",
    "react-i18next": "catalog:",
    "vortex-api": "catalog:"
  }
}
