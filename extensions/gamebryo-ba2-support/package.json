{
  "name": "gamebryo-ba2-support",
  "version": "0.0.1",
  "description": "Support for new Gamebryo data archives",
  "scripts": {
    "_build": "node build.mjs && pnpm extractInfo",
    "build": "node -e \"if(process.platform==='win32')process.exit(1)\" || (pnpm run _build && node ../copy-extension.mjs out)",
    "dist": "node -e \"if(process.platform==='win32')process.exit(1)\" || (pnpm run _build && node ../copy-extension.mjs dist)",
    "typecheck": "pnpm tsc"
  },
  "author": "Black Tree Gaming Ltd.",
  "license": "GPL-3.0",
  "type": "commonjs",
  "private": true,
  "config": {
    "extensionName": "Gamebryo BA2 Support"
  },
  "devDependencies": {
    "@types/i18next": "catalog:",
    "@types/rimraf": "catalog:",
    "bluebird": "catalog:",
    "copyfiles": "catalog:",
    "rimraf": "catalog:",
    "vortex-api": "workspace:*"
  }
}
