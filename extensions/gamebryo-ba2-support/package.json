{
  "name": "gamebryo-ba2-support",
  "version": "0.0.1",
  "description": "Support for new gamebryo data archives",
  "main": "./out/index.js",
  "scripts": {
    "_native": "node ../copy-native.mjs ./node_modules/ba2tk/build/Release/ba2tk.node",
    "_build": "node build.mjs && pnpm run _native && extractInfo",
    "build": "node -e \"if(process.platform==='win32')process.exit(1)\" || (pnpm run _build && node ../copy-extension.mjs gamebryo-ba2-support out)",
    "dist": "node -e \"if(process.platform==='win32')process.exit(1)\" || (pnpm run _build && node ../copy-extension.mjs gamebryo-ba2-support dist)"
  },
  "author": "Black Tree Gaming Ltd.",
  "license": "GPL-3.0",
  "devDependencies": {
    "@types/i18next": "catalog:",
    "@types/rimraf": "catalog:",
    "ba2tk": "catalog:",
    "bluebird": "catalog:",
    "copyfiles": "catalog:",
    "rimraf": "catalog:",
    "vortex-api": "catalog:"
  }
}
