{
  "name": "script-extender-installer",
  "version": "1.1.14",
  "description": "Install script extenders for Gamebyro games with Vortex",
  "main": "./out/index.js",
  "repository": "",
  "scripts": {
    "webpack": "webpack --config webpack.config.js --progress --profile --color",
    "bundle7z": "7z a -t7z script-extender-installer.7z .\\dist\\index.js .\\dist\\info.json",
    "_build": "npm run webpack && extractInfo",
    "build": "npm run _build && copyfiles -u 1 dist/**/* ../../src/main/out/bundledPlugins/script-extender-installer",
    "dist": "npm run _build && copyfiles -u 1 dist/**/* ../../src/main/dist/bundledPlugins/script-extender-installer"
  },
  "author": "Pickysaurus",
  "license": "GPL-3.0",
  "babel": {
    "presets": [
      "es2015"
    ]
  },
  "devDependencies": {
    "7z-bin": "catalog:",
    "@types/node": "catalog:",
    "electron": "catalog:",
    "exe-version": "catalog:",
    "nexus-api": "catalog:",
    "react": "catalog:",
    "react-bootstrap": "catalog:",
    "redux": "catalog:",
    "typescript": "catalog:",
    "vortex-api": "catalog:",
    "vortex-ext-dependencies": "catalog:",
    "@nexusmods/nexus-api": "catalog:",
    "webpack": "catalog:",
    "webpack-cli": "catalog:",
    "bluebird": "catalog:",
    "@types/bluebird": "catalog:",
    "lodash": "catalog:",
    "@types/lodash": "catalog:",
    "copyfiles": "catalog:"
  },
  "dependencies": {
    "semver": "catalog:"
  }
}
