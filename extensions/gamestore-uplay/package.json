{
  "name": "gamestore-uplay",
  "version": "0.0.4",
  "description": "Provides discovery and launch support for Uplay games",
  "scripts": {
    "build": "node build.mjs && pnpm extractInfo",
    "typecheck": "pnpm tsc"
  },
  "author": "Black Tree Gaming Ltd.",
  "license": "GPL-3.0",
  "type": "commonjs",
  "private": true,
  "config": {
    "extensionName": "Game Store: Uplay"
  },
  "devDependencies": {
    "@types/bluebird": "catalog:",
    "@types/node": "catalog:",
    "bluebird": "catalog:",
    "copyfiles": "catalog:",
    "typescript": "catalog:",
    "vortex-api": "workspace:*",
    "winapi-bindings": "catalog:"
  },
  "nx": {
    "tags": [
      "vortex:extension"
    ],
    "targets": {
      "build": {
        "inputs": [
          "default",
          "typescript",
          "vortex-api"
        ]
      },
      "typecheck": {
        "inputs": [
          "default",
          "typescript",
          "vortex-api"
        ]
      }
    }
  }
}
