{
  "name": "mo-import",
  "version": "0.0.2",
  "description": "Import Mods from Mod Organizer",
  "main": "./out/index.js",
  "repository": "",
  "scripts": {
    "webpack": "webpack --config webpack.config.js --progress --profile --color",
    "installDev": "copyfiles -f dist/* ../../out/bundledPlugins/mo-import",
    "_build": "npm run webpack && copyfiles -f src/stylesheets/mo-import.scss dist && extractInfo",
    "build": "npm run _build && node ../copy-extension.mjs mo-import out",
    "buildDev": "npm run build",
    "dist": "npm run _build && node ../copy-extension.mjs mo-import dist"
  },
  "author": "Black Tree Gaming Ltd.",
  "license": "GPL-3.0",
  "babel": {
    "presets": [
      "es2015"
    ]
  },
  "devDependencies": {
    "@types/i18next": "catalog:",
    "@types/immutability-helper": "catalog:",
    "@types/react": "catalog:",
    "@types/react-bootstrap": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/react-redux": "catalog:",
    "@types/react-router": "catalog:",
    "copyfiles": "catalog:",
    "i18next": "catalog:",
    "immutability-helper": "catalog:",
    "json-loader": "catalog:",
    "modmeta-db": "catalog:",
    "react": "catalog:",
    "react-bootstrap": "catalog:",
    "react-dom": "catalog:",
    "react-i18next": "catalog:",
    "semver": "catalog:",
    "shortid": "catalog:",
    "vortex-ext-dependencies": "catalog:",
    "vortex-parse-ini": "catalog:",
    "webpack": "catalog:",
    "webpack-cli": "catalog:",
    "bluebird": "catalog:",
    "@types/bluebird": "catalog:",
    "redux": "catalog:",
    "vortex-api": "catalog:"
  }
}
