{
  "name": "modtype-dinput",
  "version": "0.1.0",
  "description": "Support for dinput mods",
  "scripts": {
    "_build": "node build.mjs && pnpm extractInfo",
    "build": "pnpm run _build && node ../copy-extension.mjs out",
    "dist": "pnpm run _build && node ../copy-extension.mjs dist",
    "typecheck": "pnpm tsc"
  },
  "author": "Black Tree Gaming Ltd.",
  "license": "GPL-3.0",
  "type": "commonjs",
  "private": true,
  "config": {
    "extensionName": "Mod Type: dinput"
  },
  "devDependencies": {
    "@types/bluebird": "catalog:",
    "@types/i18next": "catalog:",
    "@types/redux": "catalog:",
    "bluebird": "catalog:",
    "copyfiles": "catalog:",
    "vortex-api": "workspace:*"
  }
}
