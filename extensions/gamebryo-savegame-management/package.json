{
  "name": "gamebryo-savegame-management",
  "version": "0.2.0",
  "description": "Management for gamebryo savegames",
  "main": "./dist/index.js",
  "repository": "",
  "scripts": {
    "_assets": "copyfiles -u 1 -f src/stylesheets/savegame_management.scss dist",
    "_native": "copyfiles -u 1 -f ./node_modules/gamebryo-savegame/build/Release/GamebryoSave.node ./node_modules/gamebryo-savegame/dist/liblz4.dll ./node_modules/gamebryo-savegame/dist/zlib.dll dist",
    "_build": "pnpm webpack --config webpack.config.js --progress --profile --color && pnpm run _assets && pnpm run _native && extractInfo",
    "build": "node -e \"if(process.platform==='win32')process.exit(1)\" || (pnpm run _build && node ../copy-extension.mjs gamebryo-savegame-management out)",
    "dist": "node -e \"if(process.platform==='win32')process.exit(1)\" || (pnpm run _build && node ../copy-extension.mjs gamebryo-savegame-management dist)"
  },
  "author": "Black Tree Gaming Ltd.",
  "license": "GPL-3.0",
  "babel": {
    "presets": [
      "es2015"
    ]
  },
  "devDependencies": {
    "@types/immutability-helper": "catalog:",
    "@types/react": "catalog:",
    "@types/react-bootstrap": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/react-redux": "catalog:",
    "@types/react-router": "catalog:",
    "@types/redux": "catalog:",
    "@types/redux-thunk": "catalog:",
    "babel-loader": "catalog:",
    "bluebird": "catalog:",
    "copyfiles": "catalog:",
    "i18next": "catalog:",
    "immutability-helper": "catalog:",
    "lodash": "catalog:",
    "prop-types": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-i18next": "catalog:",
    "react-redux": "catalog:",
    "react-select": "catalog:",
    "redux": "catalog:",
    "redux-act": "catalog:",
    "redux-thunk": "catalog:",
    "ts-loader": "catalog:",
    "turbowalk": "catalog:",
    "vortex-api": "catalog:",
    "vortex-parse-ini": "catalog:",
    "webpack": "catalog:",
    "webpack-cli": "catalog:"
  },
  "optionalDependencies": {
    "gamebryo-savegame": "catalog:"
  }
}
