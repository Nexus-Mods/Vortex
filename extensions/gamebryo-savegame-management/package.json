{
  "name": "gamebryo-savegame-management",
  "version": "0.2.0",
  "description": "Management for gamebryo savegames",
  "main": "./dist/index.js",
  "repository": "",
  "scripts": {
    "webpack": "node ./node_modules/webpack/bin/webpack --config webpack.config.js --progress --profile --color",
    "clear": "rm-local-modules",
    "copyfiles": "copyfiles -f ./node_modules/gamebryo-savegame/build/Release/GamebryoSave.node ./dist && copyfiles -f ./node_modules/gamebryo-savegame/dist/liblz4.dll ./dist && copyfiles -f ./node_modules/gamebryo-savegame/dist/zlib.dll ./dist && copyfiles -f src/stylesheets/savegame_management.scss dist",
    "build": "node -e \"if(process.platform==='win32')process.exit(1)\" || npm run _build",
    "_build": "npm run webpack && npm run copyfiles && extractInfo && copyfiles -u 1 dist/**/* ../../src/main/out/bundledPlugins/gamebryo-savegame-management",
    "installDev": "copyfiles -u 1 dist/**/* ../../out/bundledPlugins/gamebryo-savegame-management",
    "buildDev": "npm run build && npm run installDev",
    "_dist": "npm run webpack && npm run copyfiles && extractInfo && copyfiles -u 1 dist/**/* ../../src/main/dist/bundledPlugins/gamebryo-savegame-management",
    "dist": "node -e \"if(process.platform==='win32')process.exit(1)\" || npm run _dist"
  },
  "author": "Black Tree Gaming Ltd.",
  "license": "GPL-3.0",
  "babel": {
    "presets": [
      "es2015"
    ]
  },
  "devDependencies": {
    "@types/immutability-helper": "catalog:",
    "@types/react": "catalog:",
    "@types/react-bootstrap": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/react-redux": "catalog:",
    "@types/react-router": "catalog:",
    "@types/redux": "catalog:",
    "@types/redux-thunk": "catalog:",
    "babel-loader": "catalog:",
    "bluebird": "catalog:",
    "copyfiles": "catalog:",
    "gamebryo-savegame": "catalog:",
    "i18next": "catalog:",
    "immutability-helper": "catalog:",
    "lodash": "catalog:",
    "prop-types": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-i18next": "catalog:",
    "react-redux": "catalog:",
    "react-select": "catalog:",
    "redux": "catalog:",
    "redux-act": "catalog:",
    "redux-thunk": "catalog:",
    "ts-loader": "catalog:",
    "turbowalk": "catalog:",
    "vortex-api": "catalog:",
    "vortex-parse-ini": "catalog:",
    "webpack": "catalog:",
    "webpack-cli": "catalog:"
  }
}
