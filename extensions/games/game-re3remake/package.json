{
  "name": "game-re3remake",
  "version": "0.1.5",
  "description": "Support for Resident Evil 3 (2020)",
  "scripts": {
    "_assets": "copyfiles -u 1 -f ./assets/* dist",
    "build": "copyfiles -u 1 -f ./src/index.js dist && pnpm run _assets && pnpm extractInfo"
  },
  "author": "Black Tree Gaming Ltd.",
  "license": "GPL-3.0",
  "type": "commonjs",
  "private": true,
  "config": {
    "game": "Resident Evil 3 (2020)"
  },
  "devDependencies": {
    "vortex-api": "workspace:*"
  },
  "nx": {
    "tags": [
      "vortex:extension"
    ],
    "targets": {
      "build": {
        "inputs": [
          "default",
          "typescript",
          "vortex-api"
        ]
      },
      "typecheck": {
        "inputs": [
          "default",
          "typescript",
          "vortex-api"
        ]
      }
    }
  }
}
