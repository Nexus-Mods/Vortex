{
  "name": "game-cyberpunk2077",
  "version": "0.1.0",
  "description": "This is a stub of the Cyberpunk 2077 extension. It will be downloaded the first time it's managed.",
  "author": "Black Tree Gaming Ltd.",
  "license": "GPL-3.0",
  "type": "commonjs",
  "private": true,
  "config": {
    "game": "Cyberpunk 2077"
  },
  "scripts": {
    "_assets": "copyfiles -u 1 -f ./assets/* dist",
    "build": "copyfiles -u 1 -f ./src/index.js dist && pnpm run _assets && pnpm extractInfo"
  },
  "devDependencies": {
    "vortex-api": "workspace:*"
  },
  "nx": {
    "tags": [
      "vortex:extension"
    ],
    "targets": {
      "build": {
        "inputs": [
          "default",
          "typescript",
          "vortex-api"
        ]
      },
      "typecheck": {
        "inputs": [
          "default",
          "typescript",
          "vortex-api"
        ]
      }
    }
  }
}
