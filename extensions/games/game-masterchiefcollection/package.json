{
  "name": "game-masterchiefcollection",
  "version": "1.1.3",
  "description": "Support for Halo: The Master Chief Collection",
  "main": "dist/index.js",
  "scripts": {
    "_assets": "copyfiles -u 1 -f ./assets/* dist",
    "_build": "node build.mjs && pnpm run _assets && extractInfo",
    "build": "pnpm run _build && node ../../copy-extension.mjs out",
    "dist": "pnpm run _build && node ../../copy-extension.mjs dist"
  },
  "author": "Black Tree Gaming Ltd.",
  "license": "GPL-3.0",
  "type": "commonjs",
  "private": true,
  "config": {
    "game": "Halo: The Master Chief Collection"
  },
  "devDependencies": {
    "vortex-api": "workspace:*"
  }
}
