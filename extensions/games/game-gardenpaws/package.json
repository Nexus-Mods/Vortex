{
  "name": "game-gardenpaws",
  "version": "0.1.0",
  "description": "Support for Garden Paws",
  "main": "dist/index.js",
  "scripts": {
    "_assets": "copyfiles -u 1 -f ./assets/* dist",
    "_build": "copyfiles -u 1 -f ./src/*.js dist && pnpm run _assets && extractInfo",
    "build": "pnpm run _build && node ../../copy-extension.mjs out",
    "dist": "pnpm run _build && node ../../copy-extension.mjs dist"
  },
  "author": "m0nster",
  "license": "GPL-3.0",
  "type": "commonjs",
  "private": true,
  "config": {
    "game": "Garden Paws"
  },
  "devDependencies": {
    "vortex-api": "catalog:"
  }
}
