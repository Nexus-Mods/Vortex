{
  "name": "game-stardewvalley",
  "version": "0.3.9",
  "description": "Support for Stardew Valley",
  "scripts": {
    "_assets": "copyfiles -u 1 -f ./assets/* dist/assets && copyfiles -u 2 -f ./src/ui/sdvstyle.scss dist/ui",
    "_build": "node build.mjs && pnpm run _assets && pnpm extractInfo",
    "typecheck": "pnpm exec tsc -p tsconfig.json",
    "test": "vitest run --config vitest.config.ts",
    "build": "pnpm run _build && node ../../copy-extension.mjs out",
    "dist": "pnpm run _build && node ../../copy-extension.mjs dist"
  },
  "author": "Black Tree Gaming Ltd.",
  "license": "GPL-3.0",
  "type": "commonjs",
  "private": true,
  "config": {
    "game": "Stardew Valley"
  },
  "dependencies": {
    "@vortex/paths": "workspace:*",
    "@vortex/shared": "workspace:*",
    "react": "catalog:",
    "react-bootstrap": "catalog:",
    "react-i18next": "catalog:",
    "react-redux": "catalog:",
    "redux-act": "catalog:",
    "relaxed-json": "catalog:",
    "semver": "catalog:",
    "turbowalk": "catalog:"
  },
  "devDependencies": {
    "@nexusmods/nexus-api": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-bootstrap": "catalog:",
    "@types/react-redux": "catalog:",
    "@types/relaxed-json": "catalog:",
    "@types/semver": "catalog:",
    "copyfiles": "catalog:",
    "electron": "catalog:",
    "modmeta-db": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "vortex-api": "workspace:*"
  }
}
