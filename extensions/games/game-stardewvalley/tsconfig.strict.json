{
  "$schema": "https://www.schemastore.org/tsconfig.json",
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "noEmit": true,
    "paths": {
      "vortex-api": [
        "./node_modules/vortex-api/lib/api.d.ts"
      ]
    },
    "strictNullChecks": true,
    "noUncheckedIndexedAccess": true
  },
  "include": [
    "./src/**/*.ts",
    "./src/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "out"
  ]
}
