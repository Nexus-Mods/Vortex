{
  "name": "game-witcher",
  "version": "0.1.0",
  "description": "Support for The Witcher: Enhanced Edition",
  "scripts": {
    "build": "node build.mjs",
    "test": "pnpm exec vitest run --passWithNoTests"
  },
  "author": "Evanito",
  "license": "GPL-3.0",
  "type": "commonjs",
  "private": true,
  "config": {
    "game": "The Witcher"
  },
  "devDependencies": {
    "@nexusmods/vortex-api": "workspace:*",
    "@vortex/extension-test-mocks": "workspace:*"
  },
  "nx": {
    "tags": [
      "vortex:extension"
    ],
    "targets": {
      "build": {
        "inputs": [
          "default",
          "typescript",
          "vortex-api"
        ]
      }
    }
  }
}
