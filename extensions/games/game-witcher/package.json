{
  "name": "game-witcher",
  "version": "0.1.0",
  "description": "Support for The Witcher: Enhanced Edition",
  "main": "dist/index.js",
  "scripts": {
    "_assets": "copyfiles -u 1 -f ./assets/* dist",
