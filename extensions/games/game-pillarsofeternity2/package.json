    "@types/react-dnd": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/redux": "catalog:",
    "@types/redux-thunk": "catalog:",
    "@types/semver": "catalog:",
    "bluebird": "catalog:",
    "copyfiles": "catalog:",
    "react": "catalog:",
    "react-dnd": "catalog:",
    "react-i18next": "catalog:",
    "react-redux": "catalog:",
