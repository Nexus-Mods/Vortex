{
  "name": "game-re2remake",
  "version": "0.2.6",
  "description": "Support for RE2 (2019)",
  "main": "dist/index.js",
  "scripts": {
    "_assets": "copyfiles -u 1 -f ./assets/* dist",
    "_build": "copyfiles -u 1 -f ./src/index.js dist && pnpm run _assets && extractInfo",
    "build": "pnpm run _build && node ../../copy-extension.mjs out",
    "dist": "pnpm run _build && node ../../copy-extension.mjs dist"
  },
  "author": "Black Tree Gaming Ltd.",
  "license": "GPL-3.0",
  "type": "commonjs",
  "private": true,
  "config": {
    "game": "Resident Evil 2 (2019)"
  },
  "devDependencies": {
    "vortex-api": "catalog:"
  }
}
