{
  "name": "game-xrebirth",
  "version": "1.0.1",
  "description": "Support for X Rebirth",
  "scripts": {
    "_assets": "copyfiles -u 1 -f ./assets/* dist",
    "build": "node build.mjs && pnpm run _assets && pnpm extractInfo"
  },
  "author": "Black Tree Gaming Ltd.",
  "license": "GPL-3.0",
  "type": "commonjs",
  "private": true,
  "config": {
    "game": "X Rebirth"
  },
  "vortex": {
    "gameExtensionTest": true
  },
  "dependencies": {
    "xml2js": "catalog:"
  },
  "devDependencies": {
    "@types/xml2js": "catalog:",
    "@vortex/extension-test-mocks": "workspace:*",
    "@vortex/game-extension-test": "workspace:*",
    "vortex-api": "workspace:*"
  },
  "nx": {
    "tags": [
      "vortex:extension"
    ],
    "targets": {
      "build": {
        "inputs": [
          "default",
          "typescript",
          "vortex-api"
        ]
      },
      "typecheck": {
        "inputs": [
          "default",
          "typescript",
          "vortex-api"
        ]
      },
      "test:game-extensions": {
        "executor": "nx:run-commands",
        "options": {
          "command": "pnpm --filter @vortex/game-extension-test run start -- --game game-xrebirth"
        },
        "inputs": [
          "{projectRoot}/src/**/*.ts"
        ],
        "cache": false
      }
    }
  }
}
