{
  "name": "gamebryo-archive-support",
  "version": "0.1.0",
  "description": "Support for Gamebryo/Bethesda archives (BSA and BA2)",
  "scripts": {
    "_build": "node build.mjs && pnpm extractInfo",
    "build": "node -e \"if(process.platform==='win32')process.exit(1)\" || (pnpm run _build)",
    "typecheck": "pnpm tsc"
  },
  "author": "Black Tree Gaming Ltd.",
  "license": "GPL-3.0",
  "type": "commonjs",
  "private": true,
  "config": {
    "extensionName": "Gamebryo Archive Support"
  },
  "devDependencies": {
    "@types/i18next": "catalog:",
    "@types/rimraf": "catalog:",
    "bluebird": "catalog:",
    "copyfiles": "catalog:",
    "lz4js": "^0.2.0",
    "rimraf": "catalog:",
    "tmp": "catalog:",
    "vortex-api": "workspace:*"
  },
  "nx": {
    "tags": [
      "vortex:extension"
    ],
    "targets": {
      "build": {
        "inputs": [
          "default",
          "typescript",
          "vortex-api"
        ]
      },
      "typecheck": {
        "inputs": [
          "default",
          "typescript",
          "vortex-api"
        ]
      }
    }
  }
}
