{
  "name": "mod-highlight",
  "version": "0.1.0",
  "description": "Custom highlighting (and notes) for mods",
  "scripts": {
    "_assets": "copyfiles -u 1 -f src/stylesheets/mod-highlight.scss dist",
    "_build": "node build.mjs && pnpm run _assets && pnpm extractInfo",
    "build": "pnpm run _build && node ../copy-extension.mjs out",
    "dist": "pnpm run _build && node ../copy-extension.mjs dist",
    "typecheck": "pnpm tsc"
  },
  "author": "Black Tree Gaming Ltd.",
  "license": "GPL-3.0",
  "devDependencies": {
    "@types/react": "catalog:",
    "@types/react-bootstrap": "catalog:",
    "@types/react-redux": "catalog:",
    "@types/redux": "catalog:",
    "copyfiles": "catalog:",
    "react-bootstrap": "catalog:",
    "react-dom": "catalog:",
    "react-i18next": "catalog:",
    "redux-act": "catalog:",
    "redux-thunk": "catalog:",
    "vortex-api": "workspace:*"
  }
}
