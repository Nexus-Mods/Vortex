{
  "name": "mod-highlight",
  "version": "0.1.0",
  "description": "Custom highlighting (and notes) for mods",
  "main": "./out/index.js",
  "scripts": {
    "webpack": "node ./node_modules/webpack/bin/webpack --config webpack.config.js --progress --profile --color",
    "_build": "npm run webpack && copyfiles -f src/stylesheets/mod-highlight.scss dist && extractInfo",
    "build": "npm run _build && node ../copy-extension.mjs mod-highlight out",
    "dist": "npm run _build && node ../copy-extension.mjs mod-highlight dist"
  },
  "author": "Black Tree Gaming Ltd.",
  "license": "GPL-3.0",
  "devDependencies": {
    "@types/react": "catalog:",
    "@types/react-bootstrap": "catalog:",
    "@types/react-redux": "catalog:",
    "@types/redux": "catalog:",
    "copyfiles": "catalog:",
    "react-bootstrap": "catalog:",
    "ts-loader": "catalog:",
    "vortex-api": "catalog:",
    "webpack": "catalog:",
    "webpack-cli": "catalog:",
    "react-i18next": "catalog:",
    "react-dom": "catalog:",
    "redux-thunk": "catalog:",
    "redux-act": "catalog:"
  }
}
