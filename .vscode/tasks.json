{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "setup:deps",
      "type": "shell",
      "command": "pnpm install"
    },
    {
      "label": "build",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "build"],
      "group": "build"
    },
    {
      "label": "start",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "start"]
    },
    {
      "label": "test",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "test"],
      "group": "test"
    },
    {
      "label": "lint",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "lint"],
      "problemMatcher": {
        "base": "$eslint-stylish"
      }
    }
  ]
}
